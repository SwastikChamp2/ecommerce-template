# ========================================
# Scribbly E-Commerce Environment Variables
# ========================================
# Copy this file to .env and fill in your actual values
# Never commit the .env file to version control

# ========================================
# Firebase Configuration
# ========================================
# Get these values from your Firebase project settings
# https://console.firebase.google.com/project/{your-project}/settings/general

# Firebase API Key
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key_here

# Firebase Authentication Domain
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com

# Firebase Project ID
REACT_APP_FIREBASE_PROJECT_ID=your_firebase_project_id

# Firebase Storage Bucket
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# Firebase Messaging Sender ID
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id

# Firebase App ID
REACT_APP_FIREBASE_APP_ID=your_firebase_app_id

# ========================================
# Email Configuration (Resend API)
# ========================================
# Enable or disable email functionality
# Set to 'true' to enable, 'false' to disable
REACT_APP_EMAIL_ENABLED=true

# Email address for sending order confirmations and notifications
# This should be a verified domain in your Resend account
REACT_APP_EMAIL_FROM=orders@yourdomain.com

# Support email address for customer inquiries
REACT_APP_SUPPORT_EMAIL=support@yourdomain.com

# Resend API Key for local development
# Get your API key from https://resend.com
# Format should start with 're_'
REACT_APP_RESEND_API_KEY=your_resend_api_key_here

# ========================================
# Cloudflare Pages/Functions Configuration
# ========================================
# Note: When deploying to Cloudflare Pages, set RESEND_API_KEY 
# in the Cloudflare Pages environment variables dashboard
# This is different from REACT_APP_RESEND_API_KEY used in development

# Resend API Key for Cloudflare Functions (server-side)
# Set this in Cloudflare Pages dashboard, not in .env file
# RESEND_API_KEY=your_resend_api_key_here

# ========================================
# Standard Node.js Environment Variables
# ========================================
# Environment type
NODE_ENV=development

# Public URL for the application
# Use this if your app is served from a subdirectory
PUBLIC_URL=/

# ========================================
# Additional Notes
# ========================================
# 1. Firebase Setup:
#    - Go to https://console.firebase.google.com
#    - Create a new project or select existing one
#    - Enable Firestore Database and Authentication
#    - Copy configuration from Project Settings
#
# 2. Email Setup:
#    - Sign up at https://resend.com
#    - Verify your domain for better deliverability
#    - Copy your API key (starts with 're_')
#    - Add verified email address for REACT_APP_EMAIL_FROM
#
# 3. Development vs Production:
#    - Use REACT_APP_* prefix for client-side environment variables (local development)
#    - Use plain variable names for server-side (Cloudflare Functions)
#
# 4. Never commit this file with real values!
#    - Add .env to .gitignore
#    - Share a .env.example with placeholder values
